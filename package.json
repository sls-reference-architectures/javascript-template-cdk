{
  "name": "javascript-template-cdk",
  "version": "1.0.0",
  "description": "Template for basic JavaScript serverless project in AWS CDK",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint '**.*.js' --fix",
    "prettier": "npx prettier --write .",
    "test": "npm run lint && npm run test:unit",
    "test:e2e": "STAGE=dev npx jest e2e.test --config jest.config.e2e.js",
    "test:int": "STAGE=dev npx jest int.test --config jest.config.int.js",
    "test:unit": "POWERTOOLS_DEV=true POWERTOOLS_LOGGER_SAMPLE_RATE=1 npx jest unit.test",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sls-reference-architectures/javascript-template-cdk.git"
  },
  "author": "Seth Orell",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sls-reference-architectures/javascript-template-cdk/issues"
  },
  "homepage": "https://github.com/sls-reference-architectures/javascript-template-cdk#readme",
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.1041.0",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "aws-cdk": "^2.1108.0",
    "aws-cdk-lib": "^2.253.0",
    "axios": "^1.18.1",
    "constructs": "^10.7.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-extended": "^7.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.9.5"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.33.1",
    "@middy/core": "^7.7.0"
  },
  "lint-staged": {
    "*.{js, mjs}": "eslint --cache --fix",
    "*.{js,md,mjs,yml,json}": "npx prettier . --write --ignore-path .gitignore"
  }
}
